---
// 1. Importamos o cliente do Sanity que configuramos na pasta lib
import { client } from '../lib/sanity';

// 2. Criamos a consulta (Query) para buscar todas as matérias salvas
const query = `*[_type == "post"] | order(publishedAt desc) {
  title,
  "slug": slug.current,
  publishedAt,
  "imageUrl": mainImage.asset->url
}`;

// 3. Executamos a busca dos dados na nuvem do Sanity
const materias = await client.fetch(query);
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog Imperatrânsito</title>
    <style>
    /* Configurações Globais e Cores */
    :root {
        --cor-principal: #1e293b; /* Grafite escuro */
        --cor-destaque: #f59e0b;  /* Amarelo atenção / ouro */
        --cor-fundo: #f8fafc;     /* Cinza claro suave */
        --cor-texto: #334155;     /* Grafite para leitura */
    }

    body {
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        background-color: var(--cor-fundo);
        color: var(--cor-texto);
        margin: 0;
        padding: 0;
        line-height: 1.6;
    }

    /* Cabeçalho Profissional */
    header {
        background: linear-gradient(135deg, #0f172a 0%, var(--cor-principal) 100%);
        color: white;
        padding: 2rem 1rem;
        text-align: center;
        border-bottom: 4px solid var(--cor-destaque);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }

    header h1 {
        margin: 0;
        font-size: 2.8rem;
        font-weight: 800;
        letter-spacing: -1px;
    }

    header p {
        margin: 0.75rem 0 0 0;
        color: #cbd5e1;
        font-size: 1.1rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Layout da Grade de Conteúdo */
    main {
        max-width: 1140px;
        margin: 3rem auto;
        padding: 0 1.5rem;
    }

    .grid-materias {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2.5rem;
    }

    /* Cartões de Matérias Modernos */
    .card-materia {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        display: flex;
        flex-direction: column;
    }

    .card-materia:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }

    .conteudo-card {
        padding: 1.75rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .data {
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 600;
        margin-bottom: 0.5rem;
        display: inline-block;
    }

    .card-materia h2 {
        margin: 0 0 1rem 0;
        font-size: 1.4rem;
        line-height: 1.4;
    }

    .card-materia h2 a {
        color: var(--cor-principal);
        text-decoration: none;
        transition: color 0.2s;
    }

    .card-materia h2 a:hover {
        color: #2563eb;
    }

    /* Link "Ler mais" estilo botão discreto */
    .ler-mais {
        margin-top: auto;
        color: var(--cor-principal);
        text-decoration: none;
        font-weight: 700;
        font-size: 0.95rem;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        transition: color 0.2s;
    }

    .ler-mais:hover {
        color: var(--cor-destaque);
    }

    .sem-materias {
        text-align: center;
        color: #64748b;
        font-style: italic;
        grid-column: 1 / -1;
        padding: 3rem;
        background: white;
        border-radius: 8px;
    }

    .imagem-card {
    width: 100%;
    height: 200px; /* Altura fixa padrão para os cartões ficarem alinhados */
    object-fit: cover; /* Faz a imagem preencher o espaço sem distorcer */
    border-bottom: 3px solid var(--cor-destaque); /* Linha amarela charmosa abaixo da foto */
}
</style>
</head>
<body>

    <header>
        <h1>Blog Imperatrânsito</h1>
        <p>Condutor educado, trânsito seguro!</p>
    </header>

    <main>
        <section class="grid-materias">
    {materias.length > 0 ? (
        materias.map((materia) => (
            <article class="card-materia">
                
                {materia.imageUrl && (
                    <img src={materia.imageUrl} alt={materia.title} class="imagem-card" />
                )}

                <div class="conteudo-card">
                    <span class="data">
                        {new Date(materia.publishedAt).toLocaleDateString('pt-BR')}
                    </span>
                    <h2>
                        <a href={`/materia/${materia.slug}`}>
                            {materia.title}
                        </a>
                    </h2>
                    <a href={`/materia/${materia.slug}`} class="ler-mais">Ler matéria completa →</a>
                </div>

            </article>
        ))
    ) : (
        <p class="sem-materias">Nenhuma matéria publicada ainda.</p>
    )}
</section>
    </main>

</body>
</html>